# Domain target: admin.xystudio.my.id
NEXT_PUBLIC_SITE_URL=https://admin.xystudio.my.id

# Branding/custom UI
ADMIN_BRAND_TITLE=XyStudio Control Center
ADMIN_BRAND_SUBTITLE=Monitor sites, BuildBox, revenue, and server actions.
ADMIN_BRAND_LOGO_URL=
ADMIN_BRAND_ACCENT=#facc15

# Admin login. Separate emails by comma.
ADMIN_ALLOWED_EMAILS=you@example.com,admin@xystudio.my.id
ADMIN_LOGIN_PASSCODE=change-this-long-admin-passcode
ADMIN_SESSION_SECRET=change-this-random-session-secret-minimum-32-characters

# GitHub monitoring token. Keep server-side only.
GITHUB_TOKEN=github_pat_xxxxxxxxx
BUILDBOX_GITHUB_OWNER=Kallxy1
BUILDBOX_FRONTEND_REPO=androidbuilderfrontend
BUILDBOX_ENGINE_REPO=androidengine

# BuildBox access key voucher issuing from admin dashboard
BUILDBOX_BASE_URL=https://build.xystudio.my.id
BUILDBOX_REWARD_CLAIM_SECRET=same-value-as-buildbox-REWARD_CLAIM_SECRET

# Sites to monitor. Optional; default includes build/admin/www.
ADMIN_SITES_JSON=[{"name":"BuildBox","url":"https://build.xystudio.my.id","type":"buildbox"},{"name":"XyStudio","url":"https://www.xystudio.my.id","type":"custom"},{"name":"Admin","url":"https://admin.xystudio.my.id","type":"admin"}]

